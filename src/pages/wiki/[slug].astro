---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { marked } from 'marked';

interface Props {
  note: any;
}

export async function getStaticPaths() {
  const GITHUB_REPO = 'hachemite/wiki-logs';
  let issues = [];

  // 1. Network Resilience: Try/Catch with Timeout
  try {
    const response = await fetch(`https://api.github.com/repos/${GITHUB_REPO}/issues?state=open`, {
      signal: AbortSignal.timeout(5000),
    });
    if (response.ok) {
      issues = await response.json();
    } else {
      console.warn(`GitHub API returned status: ${response.status}`);
    }
  } catch (error: any) {
    console.error('Failed to connect to GitHub API in [slug].astro.', error.message);
    return []; // Return empty paths so the build doesn't crash
  }

  const notes = issues.filter((issue: any) => !issue.pull_request);

  // 2. Map issue numbers to the [slug] parameter
  return notes.map((note: any) => ({
    params: { slug: note.number.toString() },
    props: { note },
  }));
}

const { note } = Astro.props;

// 3. Convert GitHub Markdown to HTML
const contentHtml = marked.parse(note.body || '*No content provided.*');
const publishDate = new Date(note.created_at);

// 4. SEO Resilience: Strip markdown AND line breaks (\n)
const rawText = note.body
  ? note.body
      .replace(/[#*`_>\[\]]/g, '')
      .replace(/\n/g, ' ')
      .substring(0, 150) + '...'
  : 'Technical Wiki Note';
---

<BaseLayout title={`${note.title} | Wiki | Hachem Squalli`} description={rawText}>
  <div class="mb-8">
    <a
      href="/wiki"
      class="text-ink/60 hover:text-bronze font-mono text-xs decoration-dotted underline-offset-4 hover:underline"
    >
      cd ..
    </a>
  </div>

  <article class="mx-auto max-w-2xl">
    <header class="border-ink mb-12 border-b-2 pb-6">
      <div class="text-ink/40 mb-2 flex gap-4 font-mono text-xs">
        <span>FILE_ID: GH_ISSUE_{note.number}</span>
        <span>AUTHOR: {note.user?.login || 'hachemite'}</span>
      </div>

      <h1 class="text-ink mb-6 font-sans text-3xl leading-tight font-bold md:text-4xl">
        {note.title}
      </h1>

      <div class="flex items-center justify-between font-mono text-xs">
        <span class="text-bronze bg-sand border-bronze border px-2 py-1">
          {publishDate.toISOString().split('T')[0]}
        </span>
        <div class="text-ink/60 flex gap-2">
          {/* 5. Edge Case Resilience: Optional Chaining on labels */}
          {note.labels?.map((t: any) => <span>#{t.name}</span>)}
        </div>
      </div>
    </header>

    <div class="prose-industrial" set:html={contentHtml} />
  </article>

  <div class="border-ink/10 text-ink/30 mt-24 border-t pt-8 text-center font-mono text-xs">
    --- END OF FILE ---
  </div>
</BaseLayout>
