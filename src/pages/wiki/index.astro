---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch from GitHub
const GITHUB_REPO = 'hachemite/wiki-logs';

let issues = [];
try {
    // We wrap the fetch in a try/catch so if your internet drops, the site doesn't crash
    const response = await fetch(`https://api.github.com/repos/${GITHUB_REPO}/issues?state=open`, {
        signal: AbortSignal.timeout(5000) 
    });
    if (response.ok) {
        issues = await response.json();
    } else {
        console.warn(`GitHub API returned status: ${response.status}`);
    }
} catch (error: any) {
    console.error("Failed to connect to GitHub API. Using empty fallback array.", error.message);
}

const allNotes = issues.filter((issue: any) => !issue.pull_request);

function getTerminalDate(dateString: string) {
    if (!dateString) return '';
    const d = new Date(dateString);
    const month = d.toLocaleString('en-US', { month: 'short' });
    const day = d.getDate().toString().padStart(2, ' ');
    const time = d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
    return `${month} ${day} ${time}`;
}

function getSize(txt: string) {
    return ((txt?.length || 0) + 500).toString().padStart(5, ' ');
}
---

<BaseLayout title="Wiki_Logs | Hachem Squalli">

    <div class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mb-2 font-sans">DIGITAL_GARDEN</h1>
        <p class="text-ink/60 font-mono text-sm">> Establishing SSH connection to GitHub...</p>
    </div>

    <div class="w-full bg-[#1e1e1e] text-[#d4d4d4] p-4 md:p-6 rounded-sm shadow-hard font-mono text-sm md:text-base overflow-hidden">
        
        <div class="mb-4 flex items-center">
            <span class="text-[#4ec9b0] font-bold">root@hachemite</span>:<span class="text-[#569cd6]">~/wiki</span>#&nbsp;
            <span id="cmd-desktop" class="text-[#ce9178] hidden md:inline"></span>
            <span id="cmd-mobile" class="text-[#ce9178] md:hidden"></span>
            <span id="cursor" class="animate-pulse bg-[#d4d4d4] text-black px-1 ml-1">_</span>
        </div>

        <div id="terminal-output" class="opacity-0 transition-opacity duration-150">
            
            <div class="opacity-50 hidden md:block mb-2">total {allNotes.length + 2}</div>

            <div class="hidden md:flex hover:bg-white/10 w-fit whitespace-pre leading-relaxed">
                <span class="text-[#569cd6]">drwxr-xr-x</span>  4 <span class="text-[#ce9178]">hache</span>  <span class="text-[#ce9178]">staff</span>   4.0K {getTerminalDate(new Date().toISOString())} <span class="text-[#569cd6] font-bold">.</span>
            </div>
            <div class="hidden md:flex hover:bg-white/10 w-fit whitespace-pre leading-relaxed mb-2">
                <span class="text-[#569cd6]">drwxr-xr-x</span>  8 <span class="text-[#ce9178]">hache</span>  <span class="text-[#ce9178]">staff</span>   4.0K {getTerminalDate('2024-01-01T00:00:00Z')} <a href="/" class="text-[#569cd6] font-bold hover:underline">..</a>
            </div>

            <div class="flex flex-col md:whitespace-pre md:leading-relaxed">
                {allNotes.map((note: any) => (
                    <a href={`/wiki/${note.number}`} class="group flex flex-col md:flex-row md:items-center hover:bg-white/10 transition-colors decoration-none py-3 md:py-0 border-b border-white/5 md:border-transparent">
                        
                        <div class="hidden md:flex items-center gap-3 pr-4 shrink-0 min-w-max">
                            <span class="text-ink/50">-rw-r--r--</span>  
                            <span class="text-ink/50 w-4 text-right shrink-0">{note.number}</span>
                            <span class="text-[#ce9178]">{note.user?.login || 'hachemite'}</span>  
                            <span class="text-[#ce9178]">staff</span>  
                            <span>{getSize(note.body)}</span> 
                            <span class="text-[#6a9955]">{getTerminalDate(note.created_at)}</span> 
                        </div>

                        <div class="flex items-center justify-between w-full md:w-auto">
                            <span class="text-[#d4d4d4] font-bold text-base md:text-sm group-hover:text-white group-hover:underline decoration-dotted underline-offset-4">
                                {note.title}<span class="text-ink/30 font-normal">.md</span>
                            </span>
                            
                            <span class="md:hidden text-ink/40">↗</span>
                        </div>

                        <span class="ml-4 text-ink/40 hidden md:inline">
                            {/* Optional Chaining for resilience */}
                            {note.labels?.map((l: any) => `[${l.name}]`).join(' ')}
                        </span>
                        
                        <div class="flex md:hidden gap-2 mt-2">
                            {note.labels?.map((l: any) => (
                                <span class="text-[10px] text-ink/60 bg-white/5 px-1.5 py-0.5 rounded-sm">#{l.name}</span>
                            ))}
                        </div>
                    </a>
                ))}
            </div>
            
            <div class="mt-4 md:mt-2 flex items-center">
                <span class="text-[#4ec9b0] font-bold">root@hachemite</span>:<span class="text-[#569cd6]">~/wiki</span># <span class="animate-pulse bg-[#d4d4d4] text-black px-1 ml-1">_</span>
            </div>
        </div>

    </div>
</BaseLayout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const output = document.getElementById('terminal-output');
        const promptDesktop = document.getElementById('cmd-desktop');
        const promptMobile = document.getElementById('cmd-mobile');
        const topCursor = document.getElementById('cursor');

        // Check if user is on mobile
        const isMobile = window.innerWidth <= 768;
        
        // Mobile uses the clean 'ls -1', Desktop uses the full 'ls -lah'
        const cmd = isMobile ? 'ls -1 --color' : 'ls -lah --color=always';
        const target = isMobile ? promptMobile : promptDesktop;

        let i = 0;
        
        // Safe clear
        if (target) target.innerHTML = '';

        // Typewriter function
        function typeWriter() {
            if (i < cmd.length) {
                // Safe append inside the closure
                if (target) target.innerHTML += cmd.charAt(i);
                i++;
                // Randomize typing speed slightly for realism (30ms - 80ms)
                setTimeout(typeWriter, Math.floor(Math.random() * 50) + 30); 
            } else {
                // Command finished typing. Hit "Enter".
                setTimeout(() => {
                    // Safe DOM manipulations inside the timeout closure
                    if (topCursor) topCursor.style.display = 'none'; 
                    if (output) {
                        output.classList.remove('opacity-0'); 
                        output.classList.add('opacity-100');
                    }
                }, 300); // 300ms pause to simulate execution time
            }
        }

        // Start typing after a short delay so the user sees it happen
        setTimeout(typeWriter, 400); 
    });
</script>