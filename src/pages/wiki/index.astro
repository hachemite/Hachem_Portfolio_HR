---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch from GitHub
const GITHUB_REPO = 'hachemite/wiki-logs';

let issues = [];
try {
  // We wrap the fetch in a try/catch so if your internet drops, the site doesn't crash
  const response = await fetch(`https://api.github.com/repos/${GITHUB_REPO}/issues?state=open`, {
    signal: AbortSignal.timeout(5000),
  });
  if (response.ok) {
    issues = await response.json();
  } else {
    console.warn(`GitHub API returned status: ${response.status}`);
  }
} catch (error: any) {
  console.error('Failed to connect to GitHub API. Using empty fallback array.', error.message);
}

const allNotes = issues.filter(
  (issue: any) => !issue.pull_request && issue.user.login === 'hachemite'
);

function getTerminalDate(dateString: string) {
  if (!dateString) return '';
  const d = new Date(dateString);
  const month = d.toLocaleString('en-US', { month: 'short' });
  const day = d.getDate().toString().padStart(2, ' ');
  const time =
    d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
  return `${month} ${day} ${time}`;
}

function getSize(txt: string) {
  return ((txt?.length || 0) + 500).toString().padStart(5, ' ');
}
---

<BaseLayout title="Wiki_Logs | Hachem Squalli">
  <div class="mb-8">
    <h1 class="mb-2 font-sans text-4xl font-bold md:text-5xl">DIGITAL_GARDEN</h1>

    <p class="text-ink-subtle mb-4 max-w-2xl text-lg">
Unpolished field notes, raw technical logs, and open research on whatever interests me.
    </p>

    <p class="text-ink-subtle font-mono text-sm">&gt; Establishing SSH connection to GitHub...</p>
  </div>

  <div
    class="shadow-hard w-full overflow-hidden rounded-sm bg-[#1e1e1e] p-4 font-mono text-sm text-[#d4d4d4] md:p-6 md:text-base"
  >
    <div class="mb-4 flex items-center">
      <span class="font-bold text-[#4ec9b0]">root@hachemite</span>:<span class="text-[#569cd6]"
        >~/wiki</span
      >#&nbsp;
      <span id="cmd-desktop" class="hidden text-[#ce9178] md:inline"></span>
      <span id="cmd-mobile" class="text-[#ce9178] md:hidden"></span>
      <span id="cursor" class="ml-1 animate-pulse bg-[#d4d4d4] px-1 text-black">_</span>
    </div>

    <div id="terminal-output" class="opacity-0 transition-opacity duration-150">
      <div class="mb-2 hidden opacity-50 md:block">total {allNotes.length + 2}</div>

      <div class="hidden w-fit leading-relaxed whitespace-pre hover:bg-white/10 md:flex">
        <span class="text-[#569cd6]">drwxr-xr-x</span> 4 <span class="text-[#ce9178]">hache</span>
        <span class="text-[#ce9178]">staff</span> 4.0K {getTerminalDate(new Date().toISOString())}
        <span class="font-bold text-[#569cd6]">.</span>
      </div>
      <div class="mb-2 hidden w-fit leading-relaxed whitespace-pre hover:bg-white/10 md:flex">
        <span class="text-[#569cd6]">drwxr-xr-x</span> 8 <span class="text-[#ce9178]">hache</span>
        <span class="text-[#ce9178]">staff</span> 4.0K {getTerminalDate('2024-01-01T00:00:00Z')}
        <a href="/" class="font-bold text-[#569cd6] hover:underline">..</a>
      </div>

      <div class="flex flex-col md:leading-relaxed md:whitespace-pre">
        {
          allNotes.map((note: any) => (
            <a
              href={`/wiki/${note.number}`}
              class="group decoration-none flex flex-col border-b border-white/5 py-3 transition-colors hover:bg-white/10 md:flex-row md:items-center md:border-transparent md:py-0"
            >
              <div class="hidden min-w-max shrink-0 items-center gap-3 pr-4 md:flex">
                <span class="text-ink-subtle">-rw-r--r--</span>
                <span class="text-ink-subtle w-4 shrink-0 text-right">{note.number}</span>
                <span class="text-[#ce9178]">{note.user?.login || 'hachemite'}</span>
                <span>{getSize(note.body)}</span>
                <span class="text-[#6a9955]">{getTerminalDate(note.created_at)}</span>
              </div>

              <div class="flex flex-1 items-center justify-between md:justify-start md:gap-4">
                <span class="text-base font-bold text-[#d4d4d4] decoration-dotted underline-offset-4 group-hover:text-white group-hover:underline md:text-sm">
                  {note.title}
                  <span class="text-ink-subtle font-normal">.md</span>
                </span>

                <div class="hidden md:flex md:gap-2">
                  {note.labels?.map((l: any) => (
                    <span
                      style={`color: #${l.color}`}
                      class="whitespace-nowrap opacity-80 group-hover:opacity-100"
                    >
                      [{l.name}]
                    </span>
                  ))}
                </div>

                <span class="text-ink-subtle md:hidden">↗</span>
              </div>

              <div class="mt-2 flex flex-wrap gap-2 md:hidden">
                {note.labels?.map((l: any) => (
                  <span
                    style={`color: #${l.color}; border: 1px solid #${l.color}40`}
                    class="rounded-sm bg-white/5 px-1.5 py-0.5 text-[10px]"
                  >
                    #{l.name}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-4 flex items-center md:mt-2">
        <span class="font-bold text-[#4ec9b0]">root@hachemite</span>:<span class="text-[#569cd6]"
          >~/wiki</span
        ># <span class="ml-1 animate-pulse bg-[#d4d4d4] px-1 text-black">_</span>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const output = document.getElementById('terminal-output');
    const promptDesktop = document.getElementById('cmd-desktop');
    const promptMobile = document.getElementById('cmd-mobile');
    const topCursor = document.getElementById('cursor');

    // Check if user is on mobile
    const isMobile = window.innerWidth <= 768;

    // Mobile uses the clean 'ls -1', Desktop uses the full 'ls -lah'
    const cmd = isMobile ? 'ls -1 --color' : 'ls -lah --color=always';
    const target = isMobile ? promptMobile : promptDesktop;

    let i = 0;

    // Safe clear
    if (target) target.innerHTML = '';

    // Typewriter function
    function typeWriter() {
      if (i < cmd.length) {
        // Safe append inside the closure
        if (target) target.innerHTML += cmd.charAt(i);
        i++;
        // Randomize typing speed slightly for realism (30ms - 80ms)
        setTimeout(typeWriter, Math.floor(Math.random() * 50) + 30);
      } else {
        // Command finished typing. Hit "Enter".
        setTimeout(() => {
          // Safe DOM manipulations inside the timeout closure
          if (topCursor) topCursor.style.display = 'none';
          if (output) {
            output.classList.remove('opacity-0');
            output.classList.add('opacity-100');
          }
        }, 300); // 300ms pause to simulate execution time
      }
    }

    // Start typing after a short delay so the user sees it happen
    setTimeout(typeWriter, 400);
  });
</script>
