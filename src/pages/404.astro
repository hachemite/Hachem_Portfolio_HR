---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Page Not Found">
  <div
    class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-center justify-center px-4 text-center md:px-0"
  >
    <h1 class="text-ink mb-1 font-sans text-6xl leading-none font-bold md:text-8xl">404</h1>
    <h2
      class="text-ink border-bronze mb-3 inline-block border-b-2 pb-1 font-sans text-lg font-bold tracking-widest uppercase md:text-xl"
    >
      Page_Not_Found
    </h2>
    <p class="text-ink/60 mx-auto mb-6 max-w-md text-sm leading-relaxed md:text-base">
      System is operational, but the requested directory does not exist or has been moved.
    </p>

    <div
      class="shadow-hard w-full rounded-sm bg-[#1e1e1e] p-4 text-left font-mono text-xs text-[#d4d4d4] md:p-6 md:text-sm"
    >
      <div class="flex flex-col gap-2 md:gap-3">
        <div class="flex flex-wrap gap-x-2">
          <span class="text-[#ce9178]">&gt;</span>
          <span>Request:</span>
          <span class="text-[#569cd6]">GET</span>
          <span id="bad-path" class="break-all text-white/50">/unknown_path</span>
        </div>

        <div>
          <span class="text-[#ce9178]">&gt;</span>
          <span>Status:</span>
          <span class="ml-1 font-bold text-red-400">404 NOT FOUND</span>
        </div>

        <div>
          <span class="text-[#ce9178]">&gt;</span>
          <span>Upstream:</span>
          <span class="ml-1 text-[#4ec9b0]">Hachemite_Portfolio</span>
        </div>

        <div class="flex items-center gap-2">
          <span class="text-[#ce9178]">&gt;</span>
          <span>Action:</span>
          <span class="animate-pulse bg-[#d4d4d4] px-1 text-black">_</span>
        </div>
      </div>

      <div class="mt-6 animate-[fadeIn_0.5s_ease-in_0.5s_forwards] opacity-0">
        <a
          href="/"
          class="inline-flex w-full items-center justify-center gap-2 border border-[#d4d4d4]/30 bg-black/20 px-4 py-2 text-[#d4d4d4] transition-colors hover:border-[#4ec9b0] hover:text-[#4ec9b0] md:w-auto"
        >
          <span>Return to Root ( ~/ )</span>
          <span class="mt-[-2px] text-lg leading-none">↵</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pathSpan = document.getElementById('bad-path');
    if (pathSpan) {
      const badUrl = window.location.pathname;
      pathSpan.textContent = badUrl.length > 40 ? badUrl.substring(0, 40) + '...' : badUrl;
    }
  });
</script>

<style is:global>
  /* Hides the EN/FR toggle specifically on the 404 page to prevent overlapping */
  nav .ml-auto {
    display: none !important;
  }
  /* THE ONE-PAGE LOCK 
       This surgically overrides the heavy margins from your global BaseLayout 
       so the 404 page never pushes the footer off the screen.
    */
  main.layout-main {
    padding-top: 8rem !important;
    padding-bottom: 2rem !important;
    min-height: calc(100vh - 80px) !important; /* Subtracts roughly the height of your footer */
    display: flex;
    flex-direction: column;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
