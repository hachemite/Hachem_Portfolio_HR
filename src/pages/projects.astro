---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; // 1. Strict TypeScript Import

// 2. Fetch All Visible Projects
const allProjects = await getCollection('projects', ({ data }) => data.visible);

// 3. Sort by Year (Descending), then Title
const sortedProjects = allProjects.sort((a, b) => {
  if (b.data.year !== a.data.year) {
    return b.data.year - a.data.year;
  }
  return a.data.title.localeCompare(b.data.title);
});

// 4. Group by Year (Strictly typed with CollectionEntry)
const projectsByYear = sortedProjects.reduce(
  (acc, project) => {
    const year = project.data.year;
    if (!acc[year]) acc[year] = [];
    acc[year].push(project);
    return acc;
  },
  {} as Record<number, CollectionEntry<'projects'>[]>
);

const years = Object.keys(projectsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title="Projects | Hachem Squalli"
  description="Selected case studies in infrastructure, automation, and autonomous agents by Hachem Squalli."
>
  <div class="mb-16">
    <h1 class="mb-4 text-4xl font-bold md:text-5xl">PROJECTS</h1>
    <p class="text-ink-subtle max-w-2xl text-lg">
      Selected case studies in infrastructure, automation, and autonomous agents.
    </p>
  </div>

  <div class="space-y-24">
    {
      years.map((year) => (
        <section class="relative">
          <div class="flex flex-col gap-8 md:flex-row md:gap-16">
            <div class="flex-shrink-0 md:w-32">
              <span class="text-bronze border-bronze sticky top-24 border-b-2 pb-1 font-mono text-xl font-bold">
                {year}
              </span>
            </div>

            <div class="grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {projectsByYear[year].map((project) => (
                <ProjectCard project={project} />
              ))}
            </div>
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
