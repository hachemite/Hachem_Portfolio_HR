---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../../components/TechBadge.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets'; // 1. ADD THIS IMPORT

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.visible);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, description, year, stack, repoUrl, demoUrl, image } = project.data;
---

<BaseLayout
  title={`${title} | Case Study | Hachem Squalli`}
  description={description}
  image={image?.src}
>
  <div class="mb-8">
    <a
      href="/projects"
      class="text-ink/60 hover:text-bronze group inline-flex items-center gap-2 font-mono text-xs transition-colors"
    >
      <span class="transition-transform group-hover:-translate-x-1">←</span>
      BACK_TO_PROJECTS
    </a>
  </div>

  <article>
    <header class="border-ink mb-12 border-b-2 pb-8">
      <div class="mb-4 flex flex-col justify-between gap-4 md:flex-row md:items-baseline">
        <h1 class="text-ink mb-0 font-sans text-4xl leading-none font-bold md:text-6xl">
          {title}
        </h1>
        <span class="text-bronze font-mono text-xl font-bold">
          {year}
        </span>
      </div>

      <p class="text-ink/80 mb-6 max-w-2xl text-lg leading-relaxed md:text-xl">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-6 font-mono text-xs">
        <div class="flex flex-wrap gap-2">
          {stack.map((tech) => <TechBadge name={tech} />)}
        </div>

        <div class="border-ink/20 ml-auto flex gap-4 border-l pl-6">
          {
            repoUrl && (
              <a
                href={repoUrl}
                target="_blank"
                class="hover:text-bronze flex items-center gap-1 transition-colors"
              >
                <Icon name="simple-icons:github" />
                <span>SOURCE</span>
              </a>
            )
          }
          {
            demoUrl && (
              <a
                href={demoUrl}
                target="_blank"
                class="hover:text-bronze flex items-center gap-1 transition-colors"
              >
                <Icon name="mdi:external-link" />
                <span>LIVE_DEMO</span>
              </a>
            )
          }
        </div>
      </div>
    </header>

    {
      image && (
        <div class="border-ink bg-sand shadow-hard relative mb-16 aspect-video w-full overflow-hidden border-2">
          <Image
            src={image}
            alt={`Cover for ${title}`}
            width={1200}
            height={675}
            format="webp"
            class="image-rendering-pixelated h-full w-full object-cover contrast-110"
            loading="eager"
          />
          <div class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.1)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_4px,3px_100%] opacity-20 mix-blend-color-dodge" />
        </div>
      )
    }

    <div class="prose-industrial max-w-none">
      <Content />
    </div>
  </article>

  <hr class="border-ink/20 mt-16 mb-0" />
  <div class="flex justify-between pt-8 pb-16 font-mono text-xs">
    <a href="/projects" class="hover:text-bronze inline-flex items-center gap-1">
      <span>←</span> ALL PROJECTS
    </a>
    <a href="#" class="hover:text-bronze inline-flex items-center gap-1">
      SCROLL_TOP <span>↑</span>
    </a>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Find all images inside your Markdown content
      const images = document.querySelectorAll('.prose-industrial img');

      images.forEach((img) => {
        // If the browser fails to load the image, it might be a video
        img.addEventListener('error', async (e) => {
          const target = e.target as HTMLImageElement;
          const src = target.src;

          try {
            // Fetch only the headers to check the file type
            const response = await fetch(src, { method: 'HEAD' });
            const contentType = response.headers.get('content-type');

            // If GitHub tells us it's a video, transform the element!
            if (contentType && contentType.startsWith('video/')) {
              const video = document.createElement('video');
              video.src = src;
              video.autoplay = true;
              video.loop = true;
              video.muted = true;
              video.playsInline = true;
              video.controls = true;
              // Add your 'Sand & Dust' styling to the video
              video.className = 'w-full border-2 border-ink shadow-hard mb-6';

              // Swap the broken image with the working video
              target.parentNode?.replaceChild(video, target);
            }
          } catch (error) {
            console.warn('Could not check media type for:', src);
          }
        });
      });
    });
  </script>
</BaseLayout>
