---
import TechBadge from './TechBadge.astro';
// 1. Import the Astro Image component
import { Image } from 'astro:assets';

interface Props {
  project: any;
}

const { project } = Astro.props;
const { title, description, stack, image } = project.data;
const href = `/projects/${project.slug}`;
---

<a
  href={href}
  class="group border-ink bg-sand hover:border-bronze flex h-full flex-col border transition-colors duration-300"
>
  <div class="border-ink/10 relative aspect-video w-full overflow-hidden border-b bg-white/50">
    {
      image ? (
        // 2. Replace standard <img> with Astro <Image />
        <Image
          src={image}
          alt={title}
          width={800}
          height={450}
          format="webp"
          class="image-rendering-pixelated h-full w-full object-cover contrast-125 grayscale transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0"
        />
      ) : (
        // FALLBACK: If no image, show a pattern
        <div class="flex h-full w-full items-center justify-center bg-[radial-gradient(#494949_1px,transparent_1px)] [background-size:8px_8px] opacity-10">
          <span class="font-mono text-xs">NO_SIGNAL</span>
        </div>
      )
    }
  </div>

  <div class="flex flex-grow flex-col p-5">
    <div class="mb-3 flex items-start justify-between">
      <h3 class="text-ink group-hover:text-bronze text-lg font-bold transition-colors">
        {title}
      </h3>
    </div>

    <p class="text-ink-subtle mb-6 flex-grow text-sm leading-relaxed">
      {description}
    </p>

    <div class="border-ink/10 mt-auto flex flex-wrap gap-2 border-t pt-4">
      {stack.slice(0, 3).map((tech: string) => <TechBadge name={tech} />)}
      {
        stack.length > 3 && (
          <span class="text-ink-subtle self-center font-mono text-[10px]">+{stack.length - 3}</span>
        )
      }
    </div>
  </div>
</a>
