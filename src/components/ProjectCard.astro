---
import TechBadge from './TechBadge.astro';
// 1. Import the Astro Image component
import { Image } from 'astro:assets'; 

interface Props {
    project: any; 
}

const { project } = Astro.props;
const { title, description, stack, image } = project.data;
const href = `/projects/${project.slug}`; 
---

<a href={href} class="group flex flex-col h-full border border-ink bg-sand hover:border-bronze transition-colors duration-300">
    
    <div class="w-full aspect-video border-b border-ink/10 overflow-hidden bg-white/50 relative">
        {image ? (
            // 2. Replace standard <img> with Astro <Image />
            <Image 
                src={image} 
                alt={title}
                width={800}
                height={450}
                format="webp"
                class="w-full h-full object-cover image-rendering-pixelated grayscale contrast-125 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500"
            />
        ) : (
            // FALLBACK: If no image, show a pattern
            <div class="w-full h-full flex items-center justify-center opacity-10 bg-[radial-gradient(#494949_1px,transparent_1px)] [background-size:8px_8px]">
                <span class="font-mono text-xs">NO_SIGNAL</span>
            </div>
        )}
    </div>

    <div class="p-5 flex flex-col flex-grow">
        
        <div class="flex justify-between items-start mb-3">
            <h3 class="font-bold text-lg text-ink group-hover:text-bronze transition-colors">
                {title}
            </h3>
        </div>

        <p class="text-sm text-ink/80 mb-6 flex-grow leading-relaxed">
            {description}
        </p>

        <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-ink/10">
            {stack.slice(0, 3).map((tech: string) => (
                <TechBadge name={tech} />
            ))}
            {stack.length > 3 && (
                <span class="text-[10px] font-mono text-ink/40 self-center">+{stack.length - 3}</span>
            )}
        </div>
    </div>
</a>