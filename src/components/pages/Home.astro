---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechBadge from '../TechBadge.astro';
import BouncyGrid from '../BouncyGrid.astro';
import Header from '../Header.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/ui';

interface Props {
  lang: 'en' | 'fr';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// ── Helpers ──────────────────────────────────────────────────────────────────
/** Build a locale-aware internal URL */
const url = (path: string) =>
  lang === 'en' ? `/${path}`.replace(/\/+/, '/') : `/fr/${path}`.replace(/\/+/, '/');

// ── Config ───────────────────────────────────────────────────────────────────
const CURRENT_BOOK = 'Designing Data-Intensive Applications';
const BOOK_LINK = 'https://dataintensive.net/';

// ── Content ──────────────────────────────────────────────────────────────────
const experience = await getCollection(
  'experience',
  ({ data }) => data.visible && data.lang === lang
);
const sortedExperience = experience
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
  .slice(0, 2);

const allProjects = await getCollection('projects', ({ data }) => data.visible);
const sortedProjects = allProjects.sort((a, b) => b.data.year - a.data.year).slice(0, 3);

const allWiki = await getCollection('wiki');
const latestWiki = allWiki.sort(
  (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
)[0];
const commitTitle = latestWiki?.data.title ?? 'Initializing Wiki Infrastructure';
const commitLink = latestWiki ? `/wiki/${latestWiki.slug}` : '/wiki';

// ── Core Stack ───────────────────────────────────────────────────────────────
const myStack = [
  'Python',
  'C++',
  'Docker',
  'Kubernetes',
  'AWS',
  'Terraform',
  'Nginx',
  'Linux',
  'Node.js',
  'Astro',
];

// ── GitHub Activity (last 30 days) ───────────────────────────────────────────
const DAYS = 30;
let systemActivity: number[] = Array(DAYS).fill(0);

try {
  const res = await fetch('https://api.github.com/users/hachemite/events/public', {
    headers: { 'User-Agent': 'hachemite-portfolio' },
  });

  if (res.ok) {
    const events: Array<{ created_at: string }> = await res.json();
    const now = Date.now();

    for (const event of events) {
      const diffDays = Math.floor((now - new Date(event.created_at).valueOf()) / 86_400_000);
      if (diffDays < DAYS) systemActivity[diffDays] += 1;
    }

    const peak = Math.max(...systemActivity, 1);
    systemActivity = systemActivity.map((v) => Math.max((v / peak) * 100, 5));
  } else {
    systemActivity = Array(DAYS).fill(10);
  }
} catch {
  systemActivity = Array(DAYS).fill(10);
}
---

<BaseLayout
  title={lang === 'en'
    ? 'Hachem Squalli El Houssaini | Software & AI Engineer'
    : 'Hachem Squalli El Houssaini | Ingénieur Logiciel & IA'}
  description={t('home.signal.text') as string}
  lang={lang}
>
  <!-- Mobile hero grid -->
  <div class="mb-2 flex w-full justify-center pt-16 md:hidden">
    <BouncyGrid instanceId="mobile" />
  </div>

  <Header lang={lang} />

  <div class="mt-2 grid grid-cols-1 items-start gap-8 md:grid-cols-[1.5fr_1fr] md:gap-16">
    <!-- ── Left Column ─────────────────────────────────────────────────────── -->
    <div class="space-y-12">
      <!-- Hero Bio -->
      <section class="max-w-2xl">
        <p class="text-ink/80 mb-5 text-lg leading-relaxed">
          {
            lang === 'en' ? (
              <>
                Hello, I'm a{' '}
                <strong class="text-ink font-bold">
                  Software and Artificial Intelligence Engineer
                </strong>
                . I build <strong class="text-ink font-bold">resilient infrastructure</strong> and
                design <strong class="text-ink font-bold">intelligent pipelines</strong>. I am
                currently seeking a{' '}
                <strong class="text-ink font-bold">challenging internship</strong> to apply my
                expertise in <strong class="text-ink font-bold">DevOps</strong>,{' '}
                <strong class="text-ink font-bold">Backend architecture</strong>, and{' '}
                <strong class="text-ink font-bold">AI</strong>.
              </>
            ) : (
              <>
                Bonjour, je suis un{' '}
                <strong class="text-ink font-bold">
                  Ingénieur en Génie Logiciel et Intelligence Artificielle
                </strong>
                . Je construis des{' '}
                <strong class="text-ink font-bold">infrastructures résilientes</strong> et conçois
                des <strong class="text-ink font-bold">pipelines intelligents</strong>. Je recherche
                actuellement un{' '}
                <strong class="text-ink font-bold">stage de fin d'études (PFA)</strong> pour
                appliquer mon expertise en <strong class="text-ink font-bold">DevOps</strong>,{' '}
                <strong class="text-ink font-bold">Architecture Backend</strong>, et{' '}
                <strong class="text-ink font-bold">IA</strong>.
              </>
            )
          }
        </p>

        <ul class="text-ink/70 mb-8 space-y-2 font-mono text-sm">
          {
            lang === 'en' ? (
              <>
                <li>
                  <span class="text-bronze font-bold" /> Currently optimizing high-traffic infra @{' '}
                  <strong class="text-ink">SecOps</strong>
                </li>
                <li>
                  <span class="text-bronze font-bold" /> Seeking a{' '}
                  <strong class="text-bronze">PFA DevOps/AI Internship</strong> — July–Aug 2026
                </li>
              </>
            ) : (
              <>
                <li>
                  <span class="text-bronze font-bold" /> Optimisation de l'infra à fort trafic @{' '}
                  <strong class="text-ink">SecOps</strong>
                </li>
                <li>
                  <span class="text-bronze font-bold" /> À la recherche d'un{' '}
                  <strong class="text-bronze">stage PFA DevOps/IA</strong> — Juillet–Août 2026
                </li>
              </>
            )
          }
        </ul>

        <a
          href={url('cv')}
          class="border-ink bg-ink text-sand hover:bg-bronze hover:border-bronze inline-flex items-center gap-2 border px-6 py-3 font-mono text-sm font-bold transition-colors duration-200"
        >
          {t('hero.cv_btn')}
          <span>→</span>
        </a>
      </section>

      <!-- 01. Signal / Projects -->
      <section>
        <h2
          class="text-ink border-ink mb-6 flex items-center gap-3 border-b-2 pb-2 text-2xl font-bold"
        >
          <span class="text-bronze">01.</span>
          {t('home.signal')}
        </h2>

        <div class="mb-6">
          <span class="text-ink/40 mb-3 block font-mono text-sm">{t('home.focus')}</span>
          <div class="flex flex-wrap gap-2 font-mono text-sm">
            {
              (t('home.focus.tags') as readonly string[]).map((tag) => (
                <span class="border-ink/20 text-ink/80 hover:border-bronze cursor-default border bg-white/40 px-3 py-1.5 transition-colors">
                  [{tag}]
                </span>
              ))
            }
          </div>
        </div>

        <div class="text-ink/60 mb-6 font-mono text-sm">
          {t('home.indexing.prefix')}
          <span class="text-ink font-bold">{allProjects.length}</span>
          {t('home.indexing.suffix')}
        </div>

        <div class="mb-6 space-y-6">
          {
            sortedProjects.map((project) => (
              <a
                href={url(`projects/${project.slug}`)}
                class="group border-ink/20 hover:border-bronze relative block border-l-2 pl-4 transition-colors"
              >
                <h3 class="text-ink group-hover:text-bronze text-lg font-bold transition-colors">
                  {project.data.title}
                </h3>
                <p class="text-ink/70 mt-1 line-clamp-2 text-sm">{project.data.description}</p>
              </a>
            ))
          }
        </div>

        <a
          href={url('projects')}
          class="text-bronze inline-flex items-center gap-2 font-mono font-bold decoration-dotted underline-offset-4 transition-colors hover:underline"
        >
          &gt;&gt; {t('home.view_all_projects')}
        </a>
      </section>

      <!-- 02. Logs / Experience -->
      <section>
        <h2
          class="text-ink border-ink mb-6 flex items-center gap-3 border-b-2 pb-2 text-2xl font-bold"
        >
          <span class="text-bronze">02.</span>
          {t('home.logs')}
        </h2>

        <div class="mb-6 space-y-4">
          {
            sortedExperience.map((entry) => (
              <a
                href={url('cv')}
                class="group grid grid-cols-[80px_1fr] items-baseline gap-4 md:grid-cols-[100px_1fr]"
              >
                <span class="text-ink/50 group-hover:text-bronze font-mono text-xs transition-colors">
                  {entry.data.startDate.toISOString().substring(0, 7)}
                </span>
                <h3 class="text-ink m-0 text-base leading-tight font-bold decoration-dotted underline-offset-4 transition-all group-hover:underline">
                  {entry.data.role}{' '}
                  <span class="text-ink/40 font-normal">@ {entry.data.company}</span>
                </h3>
              </a>
            ))
          }
        </div>

        <a
          href={url('cv')}
          class="text-bronze inline-flex items-center gap-2 font-mono font-bold decoration-dotted underline-offset-4 transition-colors hover:underline"
        >
          &gt;&gt; {t('home.view_full_cv')}
        </a>
      </section>

      <!-- Contact CTA -->
      <section class="border-ink border bg-white/40 p-6 md:p-8">
        <p class="text-ink/80 mb-6 font-mono text-lg">{t('home.contact.text')}</p>
        <a
          href="mailto:workhachem@gmail.com"
          class="border-ink bg-ink text-sand hover:bg-bronze hover:border-bronze inline-flex items-center justify-center border px-6 py-3 font-mono text-sm font-bold transition-colors"
        >
          {t('home.email_btn')} ↗
        </a>
      </section>

      <!-- Telemetry -->
      <section class="border-ink/20 mt-12 border-t pt-8">
        <h2 class="text-ink/50 mb-6 font-mono text-sm font-bold tracking-widest uppercase">
          [TELEMETRY_&_STATS]
        </h2>

        <!-- Core Stack -->
        <div class="border-ink/10 mb-8 border-b pb-8">
          <span class="text-ink/40 mb-3 block font-mono text-sm">&gt;&gt; CORE_STACK</span>
          <div class="flex flex-wrap gap-2">
            {myStack.map((tech) => <TechBadge name={tech} />)}
          </div>
        </div>

        <!-- Activity Graph -->
        <div class="border-ink/10 mb-8 border-b pb-8">
          <span class="text-ink/40 mb-3 block font-mono text-sm">
            &gt;&gt; {t('home.activity.label')}
          </span>

          <div
            class="flex h-12 w-full flex-row-reverse items-end justify-start gap-[3px] overflow-hidden opacity-90"
            aria-hidden="true"
            title="GitHub Activity — Last 30 Days"
          >
            {
              systemActivity.map((val, i) => (
                <div
                  class={`w-1.5 shrink-0 transition-colors md:w-2 ${
                    i === 0
                      ? 'bg-bronze animate-pulse shadow-[0_0_5px_rgba(140,123,101,0.5)]'
                      : 'bg-ink'
                  }`}
                  style={`height:${val}%;opacity:${Math.min(val / 100 + 0.15, 1)};`}
                />
              ))
            }
          </div>

          <div class="text-ink/40 mt-2 flex justify-between font-mono text-[10px]">
            <span>[T-MINUS_30D]</span>
            <span class="text-bronze animate-pulse">[CURRENT_PULSE]</span>
          </div>
        </div>

        <!-- Latest Commit + Current Read -->
        <div class="grid grid-cols-1 gap-6 font-mono text-sm sm:grid-cols-2">
          <div>
            <span class="text-bronze mb-1 block">{t('home.commit')}</span>
            <a
              href={commitLink}
              class="hover:text-bronze line-clamp-2 underline decoration-dotted underline-offset-4 transition-colors"
            >
              {commitTitle}
            </a>
          </div>
          <div>
            <span class="text-bronze mb-1 block">{t('home.reading')}</span>
            <a
              href={BOOK_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-bronze line-clamp-2 underline decoration-dotted underline-offset-4 transition-colors"
            >
              {CURRENT_BOOK}
            </a>
          </div>
        </div>
      </section>
    </div>
    <!-- ── End Left Column ──────────────────────────────────────────────────── -->

    <!-- Desktop sticky grid -->
    <div class="sticky top-6 hidden w-full justify-end md:flex">
      <BouncyGrid instanceId="desktop" />
    </div>
  </div>
</BaseLayout>
