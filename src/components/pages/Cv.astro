---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/ui';
import { Image } from 'astro:assets';

import profileImage from '../../assets/images/profile.jpg';

interface Props {
  lang: 'en' | 'fr';
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// --- FETCH & FILTER DATA BASED ON LANGUAGE ---
const allExp = await getCollection('experience', ({ data }) => data.visible && data.lang === lang);
const allEdu = await getCollection('education', ({ data }) => data.visible && data.lang === lang);
const allCerts = await getCollection(
  'certificates',
  ({ data }) => data.visible && data.lang === lang
);
const allSkills = await getCollection('skills', ({ data }) => data.lang === lang);
const allCvProjects = await getCollection(
  'cvProjects',
  ({ data }) => data.visible && data.lang === lang
);

// --- APPLY LATEX MAPPING LOGIC ---
const workExperience = allExp
  .filter((e) => e.data.type === 'Work' || e.data.type === 'Internship')
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());

const leadership = allExp
  .filter((e) => e.data.type === 'Leadership')
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());

const honors = allCerts.sort((a, b) => b.data.date.localeCompare(a.data.date));
const skills = allSkills.sort((a, b) => a.data.priority - b.data.priority);
const education = allEdu.sort((a, b) => b.data.yearStart - a.data.yearStart);
const cvProjects = allCvProjects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout
  title={lang === 'en'
    ? 'Hachem Squalli El Houssaini | Resume & CV'
    : 'Hachem Squalli El Houssaini | CV & Parcours'}
  description={t('cv.summary.text') as string}
  lang={lang}
>
  <div class="border-ink/10 mx-auto max-w-4xl border bg-white/40 p-6 shadow-sm md:p-12">
    <header
      class="border-ink mb-8 flex flex-col items-start justify-between gap-6 border-b-2 pb-6 md:flex-row md:items-center"
    >
      <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
        <div class="shrink-0">
          <Image
            src={profileImage}
            alt="Hachem Squalli El Houssaini"
            width={237}
            height={237}
            class="border-ink shadow-hard-sm h-24 w-24 border-2 object-cover contrast-110 md:h-32 md:w-32"
            loading="eager"
          />
        </div>

        <div>
          <h1 class="text-ink mb-1 text-4xl font-bold tracking-tight md:text-5xl">
            Hachem Squalli
          </h1>
          <p class="text-bronze font-mono text-lg">{t('hero.role')}</p>
          <div class="text-ink/70 mt-3 flex flex-wrap gap-x-4 gap-y-1 font-mono text-sm">
            <a href="mailto:workhachem@gmail.com" class="hover:text-bronze">workhachem@gmail.com</a>
            <span class="hidden sm:inline">|</span>
            <a href="https://github.com/hachemite" class="hover:text-bronze">github.com/hachemite</a
            >
            <span class="hidden sm:inline">|</span>
            <span>Fès, Morocco</span>
          </div>
        </div>
      </div>

      <a
        href={lang === 'en'
          ? '/CV_HACHEM_SQUALLI_ELHOUSSAINI_ENGLISH.pdf'
          : '/CV_HACHEM_SQUALLI_ELHOUSSAINI_FRANCAIS.pdf'}
        target="_blank"
        class="border-ink bg-sand shadow-hard-sm flex shrink-0 items-center gap-2 border px-4 py-2 font-mono text-sm font-bold transition-all hover:translate-y-[2px] hover:shadow-none"
      >
        <span class="bg-bronze text-sand px-1.5 py-0.5 text-[10px] leading-none tracking-wider"
          >PDF</span
        >
        {t('cv.download')}
      </a>
    </header>

    <section class="mb-10">
      <h2
        class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase"
      >
        {t('cv.summary')}
      </h2>
      <p class="text-ink/80 leading-relaxed">
        {t('cv.summary.text')}
      </p>
    </section>

    <section class="mb-10">
      <h2
        class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase"
      >
        {t('cv.skills')}
      </h2>
      <div class="grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-2">
        {
          skills.map((skill) => (
            <div class="flex items-start gap-2">
              <span class="text-ink font-bold whitespace-nowrap">{skill.data.category}:</span>
              <span class="text-ink/80">{skill.data.items.join(', ')}</span>
            </div>
          ))
        }
      </div>
    </section>

    {
      workExperience.length > 0 && (
        <section class="mb-10">
          <h2 class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase">
            {t('cv.experience')}
          </h2>
          <div class="space-y-6">
            {workExperience.map(async (job) => {
              const { Content } = await job.render();
              return (
                <div>
                  <div class="mb-2 flex flex-col justify-between md:flex-row md:items-baseline">
                    <h3 class="text-ink text-lg font-bold">{job.data.role}</h3>
                    <span class="text-bronze font-mono text-sm">
                      {job.data.startDate.toISOString().substring(0, 7)} —{' '}
                      {job.data.current
                        ? t('cv.present')
                        : job.data.endDate?.toISOString().substring(0, 7)}
                    </span>
                  </div>
                  <div class="text-ink/60 mb-2 font-mono text-sm">
                    {job.data.company} | {job.data.location}
                  </div>
                  <div class="prose-industrial text-sm">
                    <Content />
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    {
      leadership.length > 0 && (
        <section class="mb-10">
          <h2 class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase">
            {t('cv.leadership')}
          </h2>
          <div class="space-y-6">
            {leadership.map(async (role) => {
              const { Content } = await role.render();
              return (
                <div>
                  <div class="mb-2 flex flex-col justify-between md:flex-row md:items-baseline">
                    <h3 class="text-ink text-lg font-bold">{role.data.role}</h3>
                    <span class="text-bronze font-mono text-sm">
                      {role.data.startDate.getFullYear()} —{' '}
                      {role.data.current ? t('cv.present') : role.data.endDate?.getFullYear()}
                    </span>
                  </div>
                  <div class="text-ink/60 mb-2 font-mono text-sm">{role.data.company}</div>
                  <div class="prose-industrial text-sm">
                    <Content />
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )
    }

    {
      cvProjects.length > 0 && (
        <section class="mb-10">
          <h2 class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase">
            {t('cv.projects')}
          </h2>
          <div class="space-y-6">
            {cvProjects.map((proj) => (
              <div>
                <div class="mb-1 flex flex-col justify-between md:flex-row md:items-baseline">
                  {/* CONDITIONAL LINK RENDER */}
                  <h3 class="text-ink text-lg font-bold">
                    {proj.data.projectLink ? (
                      <a
                        href={
                          lang === 'en'
                            ? `/projects/${proj.data.projectLink.id}`
                            : `/fr/projects/${proj.data.projectLink.id}`
                        }
                        class="hover:text-bronze group decoration-dotted underline-offset-4 transition-colors hover:underline"
                      >
                        {proj.data.name}
                        <span class="text-ink/40 ml-1 inline-block text-sm transition-transform group-hover:translate-x-1 group-hover:-translate-y-1">
                          ↗
                        </span>
                      </a>
                    ) : (
                      proj.data.name
                    )}
                  </h3>

                  <span class="text-bronze font-mono text-sm">{proj.data.year}</span>
                </div>
                <div class="text-ink/80 mb-2 font-mono text-sm">
                  {proj.data.role && <span class="mr-2 font-bold">{proj.data.role} |</span>}
                  <span class="text-ink/50 uppercase">{proj.data.stack.join(', ')}</span>
                </div>
                <ul class="text-ink/80 list-none space-y-1 pl-5 text-sm">
                  {proj.data.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="mb-10">
      <h2
        class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase"
      >
        {t('cv.education')}
      </h2>
      <div class="space-y-6">
        {
          education.map((edu) => (
            <div>
              <div class="mb-1 flex flex-col justify-between md:flex-row md:items-baseline">
                <h3 class="text-ink text-lg font-bold">{edu.data.degree}</h3>
                <span class="text-bronze font-mono text-sm">
                  {edu.data.yearStart} — {edu.data.yearEnd || t('cv.present')}
                </span>
              </div>
              <div class="text-ink/80 font-mono text-sm">{edu.data.institution}</div>
              <p class="text-ink/60 mt-1 text-sm">{edu.data.details}</p>
            </div>
          ))
        }
      </div>
    </section>

    {
      honors.length > 0 && (
        <section class="mb-4">
          <h2 class="text-ink border-ink/20 mb-4 border-b pb-2 font-mono text-lg font-bold tracking-widest uppercase">
            {t('cv.honors')}
          </h2>
          <ul class="space-y-3">
            {honors.map((honor) => (
              <li class="flex flex-col gap-2 md:flex-row md:items-baseline">
                <span class="text-bronze w-24 shrink-0 font-mono text-sm">{honor.data.date}</span>
                <span class="text-ink font-bold">{honor.data.title}</span>
                <span class="text-ink/60 hidden text-sm md:inline">—</span>
                <span class="text-ink/60 text-sm">{honor.data.issuer}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>
