---
const currentPath = Astro.url.pathname;
const isFr = currentPath.startsWith('/fr');

// Projects & Wiki forced to English routes
const navLinks = [
  { label: "~/", href: isFr ? "/fr" : "/" },
  { label: isFr ? "Projets" : "Projects", href: "/projects" }, // Always goes to English
  { label: "Wiki", href: "/wiki" },                            // Always goes to English
  { label: "CV", href: isFr ? "/fr/cv" : "/cv" },
];
---

<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-sand border-t-2 border-ink pb-safe shadow-[0_-4px_10px_rgba(0,0,0,0.05)]">
    <div class="flex justify-between items-center h-16 px-6">
        {navLinks.map(link => {
             const isActive = link.href === '/' || link.href === '/fr'
                    ? currentPath === link.href 
                    : currentPath.startsWith(link.href);
            
            return (
                <a href={link.href} class="flex flex-col items-center justify-center h-full w-full group no-underline">
                    <span class:list={[
                        "font-mono text-sm uppercase tracking-tight transition-all pb-1",
                        isActive 
                            ? "text-bronze font-extrabold border-b-2 border-bronze" 
                            : "text-ink/60 font-bold border-b-2 border-transparent hover:text-bronze"
                    ]}>
                        {link.label}
                    </span>
                </a>
            )
        })}
    </div>
</nav>