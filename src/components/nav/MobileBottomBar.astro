---
const currentPath = Astro.url.pathname;
const isFr = currentPath.startsWith('/fr');

// Projects & Wiki forced to English routes
const navLinks = [
  { label: '~/', href: isFr ? '/fr' : '/' },
  { label: isFr ? 'Projets' : 'Projects', href: '/projects' }, // Always goes to English
  { label: 'Wiki', href: '/wiki' }, // Always goes to English
  { label: 'CV', href: isFr ? '/fr/cv' : '/cv' },
];
---

<nav
  class="bg-sand border-ink pb-safe fixed bottom-0 left-0 z-50 w-full border-t-2 shadow-[0_-4px_10px_rgba(0,0,0,0.05)] md:hidden"
>
  <div class="flex h-16 items-center justify-between px-6">
    {
      navLinks.map((link) => {
        const isActive =
          link.href === '/' || link.href === '/fr'
            ? currentPath === link.href
            : currentPath.startsWith(link.href);

        return (
          <a
            href={link.href}
            class="group flex h-full w-full flex-col items-center justify-center no-underline"
          >
            <span
              class:list={[
                'pb-1 font-mono text-sm tracking-tight uppercase transition-all',
                isActive
                  ? 'text-bronze border-bronze border-b-2 font-extrabold'
                  : 'text-ink/60 hover:text-bronze border-b-2 border-transparent font-bold',
              ]}
            >
              {link.label}
            </span>
          </a>
        );
      })
    }
  </div>
</nav>
