---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string; // e.g., "AWS (EC2, S3)"
}

const { name } = Astro.props;

// --- 1. INTELLIGENT PARSING ---
// If name is "AWS (EC2, S3)", we only want "AWS" for the icon search.
// We split by "(" and take the first part.
const cleanName = name.split('(')[0].trim().toLowerCase();

// --- 2. THE DICTIONARY (Mappings) ---
// Map your human-readable terms to valid Simple-Icons slugs.
// --- 2. THE DICTIONARY (Mappings) ---
// Map your human-readable terms to valid Simple-Icons slugs.
const iconMap: Record<string, string> = {
  // Existing mappings...
  aws: 'amazonwebservices',
  'c++': 'cplusplus',
  'node.js': 'nodedotjs',
  'vue.js': 'vuedotjs',

  // Frameworks & Tools
  'angular 17': 'angular',
  'spring boot': 'springboot',
  'docker compose': 'docker',

  // APIs & SDKs
  'groq api': 'openai', // Fallback for AI APIs
  'telegram api': 'telegram',
  'google drive api': 'googledrive',
  'android sdk': 'android',
  'html5 canvas': 'html5',

  // Specific Libraries & Tech
  jwt: 'jsonwebtokens',
  'chart.js': 'chartdotjs',
  'rapids cuml': 'nvidia', // Mapped to NVIDIA
  ctfd: 'kalilinux', // Generic cybersecurity fallback
  'tinygps++': 'googlemaps', // Generic GPS fallback
  jdbc: 'openjdk', // Mapped directly to the safe openjdk slug,
  // 📊 Observability (Tech-Jam 2026)
  loki: 'grafana',
  promtail: 'grafana',

  // 🤖 Data Science & ML (Capital Bikeshare & ShopEase)
  catboost: 'python', // No official icon, fallback to Python
  lightgbm: 'microsoft', // Built by Microsoft
  meteostat: 'python',
  'scikit-learn': 'scikitlearn',

  // 🔌 IoT & Hardware (Smart Wheelchair)
  esp32: 'espressif', // The manufacturer of ESP32
  arduino: 'arduino',

  // 🌐 Frontend & Templating
  ejs: 'javascript', // No official EJS icon
  gsap: 'greensock', // GSAP's official brand name
  css3: 'css3',
  // ☕ The Java / Oracle Trademark Workarounds
  java: 'openjdk',
  swing: 'openjdk',

  // 🌐 Networking
  websocket: 'socketdotio', // Fallback for WebSocket

  // Update your existing wamp fallback just to be safe
  wamp: 'apache', // Apache is a more accurate representation of WAMP than PHP
};
// --- 3. DETERMINE ICON ---
// Use the map, OR fallback to removing special chars (spaces, dots)
const iconSlug = iconMap[cleanName] || cleanName.replace(/[^a-z0-9]/g, '');

const iconName = `simple-icons:${iconSlug}`;
---

<div
  class="border-ink/20 bg-sand text-ink hover:border-bronze group inline-flex cursor-default items-center gap-1.5 border px-2 py-1 whitespace-nowrap transition-colors select-none"
>
  <Icon
    name={iconName}
    class="text-ink/60 group-hover:text-bronze h-3 w-3 shrink-0 transition-colors"
    title={name}
  />

  <span class="pt-0.5 font-mono text-[10px] leading-none tracking-wide uppercase">
    {name}
  </span>
</div>
