---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string; // e.g., "AWS (EC2, S3)"
}

const { name } = Astro.props;

// --- 1. INTELLIGENT PARSING ---
// If name is "AWS (EC2, S3)", we only want "AWS" for the icon search.
// We split by "(" and take the first part.
const cleanName = name.split('(')[0].trim().toLowerCase();

// --- 2. THE DICTIONARY (Mappings) ---
// Map your human-readable terms to valid Simple-Icons slugs.
const iconMap: Record<string, string> = {
    'aws': 'amazonwebservices',
    'amazon web services': 'amazonwebservices',
    'c++': 'cplusplus',
    'cpp': 'cplusplus',
    'c#': 'csharp',
    'cs': 'csharp',
    '.net': 'dotnet',
    'dotnet': 'dotnet',
    'node.js': 'nodedotjs',
    'nodejs': 'nodedotjs',
    'vue': 'vuedotjs',
    'vue.js': 'vuedotjs',
    'golang': 'go',
    'k8s': 'kubernetes',
    'scikit-learn': 'scikitlearn',
    'rag pipelines': 'openai', // Fallback for generic AI terms
    'artificial intelligence': 'openai',
};

// --- 3. DETERMINE ICON ---
// Use the map, OR fallback to removing special chars (spaces, dots)
const iconSlug = iconMap[cleanName] || cleanName.replace(/[^a-z0-9]/g, '');

const iconName = `simple-icons:${iconSlug}`;
---

<div class="inline-flex items-center gap-1.5 px-2 py-1 border border-ink/20 bg-sand text-ink hover:border-bronze transition-colors cursor-default select-none group whitespace-nowrap">
    
<Icon 
        name={iconName} 
        class="w-3 h-3 text-ink/60 group-hover:text-bronze transition-colors shrink-0" 
        title={name} 
    />
    
    <span class="text-[10px] font-mono uppercase tracking-wide leading-none pt-0.5">
        {name}
    </span>
</div>