---
// src/components/BouncyGrid.astro
const { instanceId = 'default' } = Astro.props;
---

<div class="master-container mx-auto" id={`zone-of-dames-${instanceId}`}>
    <img id={`overlay-img-${instanceId}`} src="" alt="Hachemite" class="front-image image-rendering-pixelated" />
    <ul id={`grid-${instanceId}`}></ul>
</div>

<style is:global>
    /* We use is:global because the <li> and .cylinder-wrapper 
      elements are injected by JavaScript AFTER Astro compiles the CSS.
    */
    :root {
        /* Cylinder Dimensions */
        --cyl-width: 70px;
        --cyl-height: 70px;
        --cyl-depth: 10px;
        --cyl-half-depth: calc(var(--cyl-depth) / 2);
        --cyl-radius: calc(var(--cyl-width) / 2);
    }

    .master-container {
        position: relative;
        /* Default to desktop, JS will override for mobile */
        width: 390px;
        height: 817px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: default; 
        transition: width 0.3s, height 0.3s;
        perspective: 1200px;
        max-width: 100%; /* Ensures it doesn't break grid on small screens */
    }

    .front-image {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        z-index: 20;
        pointer-events: none; 
        mix-blend-mode: multiply; 
        object-fit: cover;
    }

    /* allow for dynamically generated IDs like grid-mobile or grid-desktop */
    #grid,
    [id^="grid-"] {
        display: grid;
        justify-content: space-between;
        align-content: space-between;
        width: 100%;
        height: 100%;
        list-style: none;
        padding: 0;
        margin: 0;
        z-index: 10;
    }

    #grid li,
    [id^="grid-"] li {
        position: relative;
        width: var(--cyl-width);
        height: var(--cyl-height);
        perspective: 1000px;
    }

    .cylinder-wrapper {
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
        transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg);
        transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
        will-change: transform;
    }

    .cylinder-wrapper:hover {
        transform: rotateX(25deg) rotateY(-25deg) rotateZ(0deg);
    }

    .cylinder-wrapper.flipped {
        transform: rotateX(0deg) rotateY(180deg) rotateZ(180deg);
    }

    .cylinder-wrapper.flipped:hover {
        transform: rotateX(25deg) rotateY(155deg) rotateZ(180deg);
    }

    .top, .bottom {
        width: var(--cyl-width);
        height: var(--cyl-height);
        border-radius: 50%;
        position: absolute;
        top: 50%; left: 50%;
        translate: -50% -50%;
        border: none; 
        outline: 1px solid transparent; 
    }

    .top {
        background: var(--color-sand);
        transform: translateZ(var(--cyl-half-depth));
    }

    .bottom {
        background: var(--color-ink);
        transform: translateZ(calc(-1 * var(--cyl-half-depth))) rotateY(180deg);
        backface-visibility: hidden; 
    }

    .strip {
        position: absolute;
        top: 50%; left: 50%;
        translate: -50% -50%;
        background: var(--color-bronze);
        height: var(--cyl-depth);
        width: calc(var(--cyl-width) / 3.7); 
        box-sizing: border-box;
        border-left: 1px solid var(--color-bronze);
        border-right: 1px solid var(--color-bronze);
    }
</style>

<script define:vars={{ instanceId }}>
    // Astro automatically runs this script once the DOM is ready
    function initBouncyGrid() {
        const grid = document.getElementById(`grid-${instanceId}`);
        const container = document.getElementById(`zone-of-dames-${instanceId}`);
        const overlayImg = document.getElementById(`overlay-img-${instanceId}`);
        
        if (!grid || !container || !overlayImg) return;

        let cols = 5; 
        let rows = 11; 
        let isCurrentlyMobile = null;

        function buildGrid() {
            const checkMobile = window.innerWidth <= 768;
            
            if (isCurrentlyMobile === checkMobile) return; 
            isCurrentlyMobile = checkMobile;

            grid.innerHTML = ''; 

            if (isCurrentlyMobile) {
                cols = 5;
                rows = 4;
                container.style.width = '350px'; 
                container.style.height = '280px'; 
                // UPDATE THIS: Path to your mobile image in the public folder
overlayImg.src = '/images/dither_it_IMG(4).png';
            } else {
                cols = 5;
                rows = 11;
                container.style.width = '390px'; 
                container.style.height = '817px';
                // UPDATE THIS: Path to your desktop image in the public folder
overlayImg.src = '/images/dither_it_IMG(3).png';            }

            grid.style.gridTemplateColumns = `repeat(${cols}, var(--cyl-width))`;
            grid.style.gridTemplateRows = `repeat(${rows}, var(--cyl-height))`;

            const cylinderCount = cols * rows; 
            const stripCount = 12;

            for (let i = 0; i < cylinderCount; i++) {
                const li = document.createElement('li');
                
                const wrapper = document.createElement('div');
                wrapper.className = 'cylinder-wrapper';
                wrapper.id = `cyl-${instanceId}-${i}`;
                
                wrapper.innerHTML = '<div class="top"></div><div class="bottom"></div>';
                
                for (let j = 0; j < stripCount; j++) {
                    const strip = document.createElement('div');
                    strip.className = 'strip';
                    strip.style.transform = `rotateZ(${j * 30}deg) translateY(calc(-1 * var(--cyl-radius))) rotateX(90deg)`;
                    wrapper.appendChild(strip);
                }
                
                wrapper.addEventListener('click', (e) => {
                    e.stopPropagation(); 
                    
                    const center = i;
                    const neighbors = [center];

                    if (center % cols !== 0) neighbors.push(center - 1); 
                    if (center % cols !== cols - 1) neighbors.push(center + 1); 
                    if (center >= cols) neighbors.push(center - cols); 
                    if (center < (rows - 1) * cols) neighbors.push(center + cols); 

                    neighbors.forEach(index => {
                        const neighborEl = document.getElementById(`cyl-${instanceId}-${index}`);
                        if (neighborEl) {
                            neighborEl.classList.toggle('flipped');
                        }
                    });
                });

                li.appendChild(wrapper);
                grid.appendChild(li);
            }
        }

        buildGrid();
        window.addEventListener('resize', buildGrid);

        container.addEventListener('click', (e) => {
            e.stopPropagation();
        });

        // The Bouncy Reset
        document.body.addEventListener('click', () => {
            const allDiscs = container.querySelectorAll('.cylinder-wrapper');
            
            allDiscs.forEach((wrapper, i) => {
                const col = i % cols;
                const row = Math.floor(i / cols);
                const staggerDelay = (col + row) * 50; 

                setTimeout(() => {
                    if (wrapper.classList.contains('flipped')) {
                        wrapper.classList.remove('flipped');
                        
                        wrapper.style.transition = 'transform 1.2s cubic-bezier(0.6, -0.6, 0.3, 1.6)';
                        wrapper.style.transform = 'rotateX(360deg) rotateY(360deg) rotateZ(360deg)';
                        
                        setTimeout(() => {
                            wrapper.style.transition = 'none'; 
                            wrapper.style.transform = ''; 
                            void wrapper.offsetWidth; 
                            wrapper.style.transition = ''; 
                        }, 1200);
                    }
                }, staggerDelay);
            });
        });
    }

    // Initialize
    initBouncyGrid();
</script>