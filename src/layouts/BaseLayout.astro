---
import '../styles/global.css';
// FIX: You must import components before using them!
import DesktopNav from '../components/nav/DesktopNav.astro';
import MobileBottomBar from '../components/nav/MobileBottomBar.astro';

interface Props {
	title: string;
	description?: string;
}

const { 
  title, 
  description = "Engineering Portfolio of Hachemite - Chef Technique @ SecOps & ILIA Student." 
} = Astro.props;

// Schema Data (SEO)
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Hachem Squalli El Houssaini", 
  "jobTitle": "Chef Technique",
  "affiliation": {
    "@type": "Organization",
    "name": "SecOps Club"
  },
  "knowsAbout": ["Docker", "Kubernetes", "AI", "Systems Engineering"]
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:type" content="profile" />
		<meta property="og:title" content={title} />
		
		<title>{title}</title>
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)} />
	</head>
	
	<body class="bg-sand text-ink overflow-x-hidden min-h-screen flex flex-col relative pb-20 md:pb-0">
		
        <DesktopNav />
        <MobileBottomBar />

        <div id="canvas-layer" class="fixed inset-0 w-full h-full z-canvas pointer-events-none opacity-50"></div>

		<main class="layout-main relative z-base flex-grow">
			<slot />
		</main>

<footer class="w-full max-w-6xl mx-auto px-4 py-8 mt-auto border-t border-ink/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono text-ink/50 mb-16 md:mb-0">
            <div>
                &copy; {new Date().getFullYear()} Hachemite. All rights reserved.
            </div>

            <div class="flex gap-4 items-center">
                <a href="https://github.com/hachemite" target="_blank" class="hover:text-bronze transition-colors">
                    Source Code ↗
                </a>
                <span class="opacity-30">|</span>
                <span>Last Update: 2026-02</span>
            </div>
        </footer>

	</body>
</html>