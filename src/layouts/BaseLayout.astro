---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { 
  title, 
  description = "Engineering Portfolio of Hachemite - Chef Technique @ SecOps & ILIA Student." 
} = Astro.props;

// 5.1 SEO Data - JSON-LD
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Hachemite", 
  "jobTitle": "Chef Technique",
  "affiliation": {
    "@type": "Organization",
    "name": "SecOps Club"
  },
  "knowsAbout": ["Docker", "Kubernetes", "AI", "Systems Engineering"]
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<meta property="og:type" content="profile" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />

        <title>{title}</title>

        <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
	</head>
	
	<body class="bg-sand text-ink overflow-x-hidden min-h-screen flex flex-col">
		
		<header class="sr-only">
			<h1>{title}</h1>
		</header>

        <div id="canvas-layer" class="fixed inset-0 w-full h-full z-canvas pointer-events-none opacity-50"></div>

		<main class="flex-grow w-full max-w-3xl mx-auto p-4 md:p-8 relative z-base">
			<slot />
		</main>

		<footer class="w-full max-w-3xl mx-auto p-4 text-xs text-bronze font-mono text-center">
			<p>SYSTEM_STATUS: ONLINE // LATENCY: ~12ms</p>
		</footer>

	</body>
</html>